PORT=8080
FRONTEND_URL=http://localhost:5173
JWT_SECRET=change-this-before-production
JWT_ACCESS_EXPIRES_IN=7d
FILE_ACCESS_EXPIRES_IN=90s
RULE_SWEEP_MS=15000
USAGE_RESET_DAYS=30
UPLOAD_SESSION_TTL_MS=86400000
REQUEST_WINDOW_MS=60000
REQUEST_LIMIT_PER_WINDOW=240
